<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Template: New Offer Received -->
        <record id="mail_template_offer_received" model="mail.template">
            <field name="name">Estate: Offer Received</field>
            <field name="model_id" ref="estate.model_estate_property_offer"/>
            <field name="subject">New Offer on {{ object.property_id.name }}</field>
            <field name="email_from">{{ (object.create_uid.email_formatted or '') }}</field>
            <field name="email_to">{{ (object.property_id.salesperson_id.email_formatted or '') }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px; font-size: 14px;">
    <p>Dear <t t-out="object.property_id.salesperson_id.name or 'Manager'"/>,</p>
    <p>A new offer has been received on property
       <strong><t t-out="object.property_id.name"/></strong>:</p>
    <ul>
        <li><strong>Buyer:</strong> <t t-out="object.partner_id.name"/></li>
        <li><strong>Offer Price:</strong> <t t-out="format_amount(object.price, object.property_id.company_id.currency_id if object.property_id.company_id else object.env.company.currency_id)"/></li>
        <li><strong>Deadline:</strong> <t t-out="format_date(object.date_deadline)"/></li>
    </ul>
    <p>Please review this offer at your earliest convenience.</p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
            <field name="lang">{{ object.property_id.salesperson_id.lang }}</field>
        </record>

        <!-- Template: Offer Accepted -->
        <record id="mail_template_offer_accepted" model="mail.template">
            <field name="name">Estate: Offer Accepted</field>
            <field name="model_id" ref="estate.model_estate_property_offer"/>
            <field name="subject">Your Offer on {{ object.property_id.name }} - Accepted</field>
            <field name="email_from">{{ (object.property_id.salesperson_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{ (object.partner_id.email_formatted or '') }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px; font-size: 14px;">
    <p>Dear <t t-out="object.partner_id.name"/>,</p>
    <p>Congratulations! Your offer on
       <strong><t t-out="object.property_id.name"/></strong>
       has been <strong style="color: green;">accepted</strong>.</p>
    <ul>
        <li><strong>Accepted Price:</strong> <t t-out="format_amount(object.price, object.property_id.company_id.currency_id if object.property_id.company_id else object.env.company.currency_id)"/></li>
    </ul>
    <p>We will contact you shortly with next steps.</p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
            <field name="lang">{{ object.partner_id.lang }}</field>
        </record>

        <!-- Template: Offer Refused -->
        <record id="mail_template_offer_refused" model="mail.template">
            <field name="name">Estate: Offer Refused</field>
            <field name="model_id" ref="estate.model_estate_property_offer"/>
            <field name="subject">Your Offer on {{ object.property_id.name }} - Refused</field>
            <field name="email_from">{{ (object.property_id.salesperson_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{ (object.partner_id.email_formatted or '') }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px; font-size: 14px;">
    <p>Dear <t t-out="object.partner_id.name"/>,</p>
    <p>We regret to inform you that your offer on
       <strong><t t-out="object.property_id.name"/></strong>
       has been <strong style="color: red;">refused</strong>.</p>
    <p>Thank you for your interest. Feel free to submit a new offer.</p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
            <field name="lang">{{ object.partner_id.lang }}</field>
        </record>

        <!-- Template: Property Sold -->
        <record id="mail_template_property_sold" model="mail.template">
            <field name="name">Estate: Property Sold</field>
            <field name="model_id" ref="estate.model_estate_property"/>
            <field name="subject">Property Sold: {{ object.name }}</field>
            <field name="email_from">{{ (object.salesperson_id.email_formatted or user.email_formatted) }}</field>
            <field name="email_to">{{ (object.buyer_id.email_formatted or '') }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px; font-size: 14px;">
    <p>Dear <t t-out="object.buyer_id.name or 'Buyer'"/>,</p>
    <p>The property <strong><t t-out="object.name"/></strong>
       has been officially marked as <strong>sold</strong>.</p>
    <ul>
        <li><strong>Final Price:</strong> <t t-out="format_amount(object.selling_price, object.company_id.currency_id if object.company_id else object.env.company.currency_id)"/></li>
    </ul>
    <p>Thank you for your business!</p>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
            <field name="lang">{{ object.buyer_id.lang }}</field>
        </record>

    </data>
</odoo>
