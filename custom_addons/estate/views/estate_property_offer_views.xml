<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== OFFER VIEWS ===== -->
    <record id="estate_property_offer_view_tree" model="ir.ui.view">
        <field name="name">estate.property.offer.tree</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <tree decoration-success="status == 'accepted'"
                  decoration-danger="status == 'refused'"
                  decoration-muted="status == 'refused'">
                <field name="partner_id"/>
                <field name="property_id"/>
                <field name="property_type_id"/>
                <field name="price" widget="monetary"/>
                <field name="validity"/>
                <field name="date_deadline"/>
                <field name="status"/>
                <button name="action_accept" type="object"
                        string="Accept" icon="fa-check"
                        invisible="status in ('accepted', 'refused')"
                        class="text-success"/>
                <button name="action_refuse" type="object"
                        string="Refuse" icon="fa-times"
                        invisible="status in ('accepted', 'refused')"
                        class="text-danger"/>
            </tree>
        </field>
    </record>

    <record id="estate_property_offer_view_form" model="ir.ui.view">
        <field name="name">estate.property.offer.form</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_accept" type="object" string="Accept"
                            invisible="status in ('accepted', 'refused')"
                            class="oe_highlight"/>
                    <button name="action_refuse" type="object" string="Refuse"
                            invisible="status in ('accepted', 'refused')"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="partner_id"/>
                        <field name="property_id"/>
                        <field name="property_type_id" readonly="1"/>
                        <field name="price" widget="monetary"/>
                        <field name="validity"/>
                        <field name="date_deadline"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_offer_action" model="ir.actions.act_window">
        <field name="name">All Offers</field>
        <field name="res_model">estate.property.offer</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('property_id.state', '!=', 'canceled')]</field>
    </record>

</odoo>
