<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ══════════════════════════════════════════
         WORK ORDER VIEWS
    ═══════════════════════════════════════════ -->

    <!-- Kanban View -->
    <record id="view_mfg_work_order_kanban" model="ir.ui.view">
        <field name="name">mfg.work.order.kanban</field>
        <field name="model">mfg.work.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="product_id"/>
                <field name="qty_to_produce"/>
                <field name="uom"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state"/>
                <field name="bom_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top mb8">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                    <div class="o_kanban_record_title text-muted">
                                        <span t-if="record.state.raw_value == 'draft'"
                                              class="badge badge-secondary">Nháp</span>
                                        <span t-if="record.state.raw_value == 'in_progress'"
                                              class="badge badge-warning">Đang SX</span>
                                        <span t-if="record.state.raw_value == 'done'"
                                              class="badge badge-success">Hoàn thành</span>
                                        <span t-if="record.state.raw_value == 'cancelled'"
                                              class="badge badge-danger">Huỷ</span>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <ul class="list-unstyled mb0">
                                        <li>
                                            <span class="text-muted">Thành phẩm: </span>
                                            <strong><field name="product_id"/></strong>
                                        </li>
                                        <li>
                                            <span class="text-muted">Số lượng: </span>
                                            <field name="qty_to_produce"/>
                                            <field name="uom"/>
                                        </li>
                                        <li t-if="record.date_start.raw_value">
                                            <span class="text-muted">Bắt đầu: </span>
                                            <field name="date_start" widget="date"/>
                                        </li>
                                    </ul>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left text-muted">
                                        <field name="bom_id"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List View -->
    <record id="view_mfg_work_order_list" model="ir.ui.view">
        <field name="name">mfg.work.order.list</field>
        <field name="model">mfg.work.order</field>
        <field name="arch" type="xml">
            <tree string="Lệnh sản xuất"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'in_progress'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="product_id"/>
                <field name="qty_to_produce"/>
                <field name="uom"/>
                <field name="bom_id" optional="show"/>
                <field name="date_start" optional="show"/>
                <field name="date_end" optional="show"/>
                <field name="location_dest_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'in_progress'"
                       decoration-danger="state == 'cancelled'"
                       decoration-info="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_mfg_work_order_form" model="ir.ui.view">
        <field name="name">mfg.work.order.form</field>
        <field name="model">mfg.work.order</field>
        <field name="arch" type="xml">
            <form string="Lệnh sản xuất">
                <header>
                    <button name="action_start" string="▶ Bắt đầu sản xuất" type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_done" string="✓ Hoàn thành" type="object"
                            class="oe_highlight"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Huỷ" type="object"
                            invisible="state in ['done', 'cancelled']"/>
                    <button name="action_reset_draft" string="Đặt lại Nháp" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Sản xuất">
                            <field name="bom_id" readonly="state != 'draft'"/>
                            <field name="product_id" readonly="1"/>
                            <field name="qty_to_produce" readonly="state != 'draft'"/>
                            <field name="uom" readonly="1"/>
                        </group>
                        <group string="Kho &amp; Thời gian">
                            <field name="location_dest_id" readonly="state != 'draft'"/>
                            <field name="date_start" readonly="1"/>
                            <field name="date_end" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Thành phần NVL (từ BOM)">
                            <p class="text-muted">
                                Xem chi tiết thành phần NVL trong Bill of Materials:
                                <field name="bom_id" readonly="1" widget="many2one"/>
                            </p>
                        </page>
                        <page string="Ghi chú">
                            <field name="note" placeholder="Ghi chú về lệnh sản xuất..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_mfg_work_order_search" model="ir.ui.view">
        <field name="name">mfg.work.order.search</field>
        <field name="model">mfg.work.order</field>
        <field name="arch" type="xml">
            <search string="Tìm lệnh sản xuất">
                <field name="name"/>
                <field name="product_id" string="Thành phẩm"/>
                <field name="bom_id"/>
                <filter name="state_draft" string="Nháp"
                        domain="[('state','=','draft')]"/>
                <filter name="state_in_progress" string="Đang sản xuất"
                        domain="[('state','=','in_progress')]"/>
                <filter name="state_done" string="Hoàn thành"
                        domain="[('state','=','done')]"/>
                <separator/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_product" string="Thành phẩm"
                            context="{'group_by': 'product_id'}"/>
                    <filter name="group_state" string="Trạng thái"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_month" string="Tháng bắt đầu"
                            context="{'group_by': 'date_start:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_mfg_work_order" model="ir.actions.act_window">
        <field name="name">Lệnh sản xuất</field>
        <field name="res_model">mfg.work.order</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_mfg_work_order_search"/>
        <field name="context">{'search_default_state_draft': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo lệnh sản xuất đầu tiên!
            </p>
            <p>Quản lý lệnh sản xuất từ khi bắt đầu đến khi nhập thành phẩm.</p>
        </field>
    </record>
</odoo>
