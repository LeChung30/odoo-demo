<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Work Orders -->
        <record id="seq_mfg_work_order" model="ir.sequence">
            <field name="name">Work Order Sequence</field>
            <field name="code">mfg.work.order</field>
            <field name="prefix">WO/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Sequence for Stock Moves -->
        <record id="seq_mfg_stock_move" model="ir.sequence">
            <field name="name">Stock Move Sequence</field>
            <field name="code">mfg.stock.move</field>
            <field name="prefix">SM/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>
</odoo>
